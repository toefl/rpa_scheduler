            <Id>cb39c37a-303b-4f90-b5a9-9e8e1ccacb71</Id>
            <Parent z:Ref="i47" />
            <PositionOnFlowchart xmlns:d7p1="http://schemas.datacontract.org/2004/07/System.Numerics" i:nil="true" />
            <PropertyValues>
              <PropertyValue z:Id="i49">
                <PropertyName>CSCode</PropertyName>
                <_dataType>Value</_dataType>
                <_expression i:nil="true" />
                <_screenShotBase64 i:nil="true" />
                <_value xmlns:d9p1="http://www.w3.org/2001/XMLSchema" i:type="d9p1:string">if (!global_context.ContainsKey("selected_project_name")) return;

// 1. Получаем и парсим JSON
System.Text.Json.JsonElement schedule_element = (System.Text.Json.JsonElement)global_context["schedule"];
using System.Text.Json.JsonDocument doc = System.Text.Json.JsonDocument.Parse(schedule_element.GetRawText());
System.Text.Json.Nodes.JsonNode schedule_node = System.Text.Json.Nodes.JsonNode.Parse(doc.RootElement.GetRawText());

// 2. Обновляем время запуска
string project_name = (string)global_context["selected_project_name"];
schedule_node[project_name]["last_run"] = DateTime.Now.ToString("dd.MM.yyyy HH:mm");

// 3. Обновляем глобальный контекст
global_context["schedule"] = System.Text.Json.JsonSerializer.SerializeToElement(schedule_node);

// 4. Сериализуем для сохранения в файл (используем System.Text.Json)
var options = new System.Text.Json.JsonSerializerOptions
{
    WriteIndented = true,
    Encoder = System.Text.Encodings.Web.JavaScriptEncoder.Create(System.Text.Unicode.UnicodeRanges.All),
    PropertyNamingPolicy = null // сохраняет оригинальные имена свойств
};

string updated_json = schedule_node.ToJsonString(options);

// 5. Сохраняем в файл
string config_file = Path.Combine(
    (string)global_context["project_root"],
    "data",
    "configs",
    "schedule.json"
);

File.WriteAllText(config_file, updated_json);

sb.Clear();
sb.AppendLine("");
sb.AppendLine("Время запуска задачи обновлено");</_value>
