sb.AppendLine("");
sb.AppendLine("Проект с расчетным временем `last_run`:");

foreach (var kvp in project)
{
    string value_string = kvp.Value?.ToString() ?? "null";
    sb.AppendLine($"  \"{kvp.Key}\": \"{value_string}\"");
}</_value>
