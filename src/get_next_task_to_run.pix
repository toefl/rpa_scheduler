                <_screenShotBase64 i:nil="true" />
                <_value xmlns:d9p1="http://www.w3.org/2001/XMLSchema" i:type="d9p1:string">sb.Clear();

int tolerance_sec = 5; //допустимая погрешность в секундах для запуска

if (executable_projects.Any())
{
    Dictionary&lt;string, object&gt; project_to_run = executable_projects
        .Where(p =&gt; (DateTime)p["next_run"] &lt;= DateTime.Now.AddSeconds(tolerance_sec)) // Фильтр: задачи, время запуска которых наступило или наступит в ближайшие tolerance_sec секунд
        .OrderBy(p =&gt; (int)p["priority"])          // чем меньше число, тем выше порядок
        .FirstOrDefault();
        
    
    if (project_to_run == null)
    {
        sb.AppendLine("");
        sb.AppendLine("╔═════════════════════════════════════════════════════════════════╗");
        sb.AppendLine("║ НЕТ ПОДХОДЯЩИХ ПРОЕКТОВ ДЛЯ ЗАПУСКА        ");
        sb.AppendLine("╚═════════════════════════════════════════════════════════════════╝");
        
        return;
    }
    
    global_context["main_file"] = project_to_run["main_file"].ToString();
    global_context["selected_project_name"] = project_to_run["name"].ToString();
    
    sb.AppendLine("");
    sb.AppendLine("╔═════════════════════════════════════════════════════════════════╗");
    sb.AppendLine($"║ ВЫБРАН ПРОЕКТ: \"{global_context["selected_project_name"]}\"");
    sb.AppendLine("╚═════════════════════════════════════════════════════════════════╝");
    sb.AppendLine();
}
else
{
    sb.AppendLine("");
    sb.AppendLine("╔═════════════════════════════════════════════════════════════════╗");
    sb.AppendLine("║ НЕТ ПОДХОДЯЩИХ ПРОЕКТОВ ДЛЯ ЗАПУСКА        ");
    sb.AppendLine("╚═════════════════════════════════════════════════════════════════╝");
}</_value>
